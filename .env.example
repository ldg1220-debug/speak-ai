# =============================================
# NewsTalk AI - 환경변수 설정 템플릿
# 이 파일을 복사해 .env.local 파일을 만들고,
# 각 값을 실제 키로 채워주세요.
# =============================================

# OpenAI API (필수)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-proj-...

# 사용할 GPT 모델 (기본값: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# GNews API (뉴스 탭에 필요)
# https://gnews.io 에서 무료 발급 (하루 100건)
GNEWS_API_KEY=...

# Supabase (선택 - 대화 기록 저장 시 필요)
# https://supabase.com 에서 프로젝트 생성 후 발급
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_KEY=...

# 개발 서버 포트 (기본값: 3000)
PORT=3000
